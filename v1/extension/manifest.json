{
  "manifest_version": 2,
  "name": "Transmigrator",
  "version": "1.0",
  "description": "A platform-agnostic tool for secure communications.",
  "permissions": [
    "storage",
    "activeTab",
    "https://*/*",
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["popup.js"],
    "persistent": false
  }
}
